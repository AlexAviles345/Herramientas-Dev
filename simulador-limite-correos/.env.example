# Configuraciones de envio de correo
# Copia este archivo como .env y coloca tus credenciales reales.
# ¡Nunca subas el archivo .env a tu repositorio de Git!

MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=tu-correo@example.com
MAIL_PASSWORD=tu-app-password

MAIL_TO=destinatario@example.com
# Opcional (por defecto usa MAIL_USERNAME)
MAIL_FROM=tu-correo@example.com

# Tiempo de espera entre cada envio (en milisegundos)
MAIL_DELAY_MS=1000
